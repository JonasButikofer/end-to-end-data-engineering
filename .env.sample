# Copy this file to .env.dev (for local development) and .env.docker (for Docker services).
# Never commit files containing real credentials.

# ============================================================================
# Milestone 1: Data Sources and ETL
# ============================================================================

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=support_logs
MONGO_COLLECTION=chats

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=transactions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# Snowflake
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=your_org-your_account        # e.g. sfedu02-abc12345
SNOWFLAKE_WAREHOUSE=your_warehouse             # e.g. boa_wh
SNOWFLAKE_DATABASE=your_database               # e.g. boa_db
SNOWFLAKE_ROLE=your_role                       # e.g. boa_role

SNOWFLAKE_SCHEMA=RAW_EXT
ORDERS_STAGE=orders_stage
ORDER_DETAILS_STAGE=order_details_stage
CHAT_STAGE=chat_stage

# Processor run mode: 0 = run once and exit, 300 = repeat every 5 minutes
PROCESSOR_INTERVAL_SEC=0

# Enable/disable COPY INTO and cleanup (for testing/debugging)
PROCESSOR_ENABLE_COPY_INTO=true
PROCESSOR_ENABLE_CLEANUP=true

# Auto-shutdown (0 = run forever)
PROCESSOR_MAX_RUNTIME_SEC=3600

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# Milestone 2: Web Analytics / Prefect
# ============================================================================

# Web Analytics REST API base URL
API_BASE_URL=https://is566-web-analytics-api.fly.dev

# Prefect server URL (leave as-is when using Docker Compose)
PREFECT_API_URL=http://prefect-server:4200/api

# Minutes between Prefect flow runs (default 15)
FLOW_SCHEDULE_MINUTES=15
